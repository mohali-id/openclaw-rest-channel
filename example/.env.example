# OpenClaw REST Channel - Gateway connection
OPENCLAW_INBOUND_URL=http://localhost:18789/rest/inbound
OPENCLAW_API_KEY=your-inbound-api-key

# Webhook secret for verifying outbound messages from OpenClaw
OPENCLAW_WEBHOOK_SECRET=your-shared-secret

# This app's public URL (for OpenClaw to send webhooks back)
# In development, use a tunnel like ngrok: https://ngrok.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
