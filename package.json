{
  "name": "openclaw-rest-channel",
  "version": "1.2.6",
  "description": "A minimal REST-based channel plugin for OpenClaw. Integrate any external web application with OpenClaw using simple HTTP requests.",
  "main": "index.ts",
  "types": "index.d.ts",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git@github.com:mohali-id/openclaw-rest-channel.git"
  },
  "homepage": "https://github.com/mohali-id/openclaw-rest-channel#readme",
  "keywords": [
    "openclaw",
    "plugin",
    "channel",
    "rest",
    "api",
    "webhook",
    "chatbot",
    "ai"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "rest",
      "label": "REST",
      "selectionLabel": "REST (HTTP API)",
      "docsPath": "/channels/rest",
      "docsLabel": "rest",
      "blurb": "Connect any external app to OpenClaw via simple HTTP requests.",
      "order": 90,
      "aliases": [
        "rest-api",
        "http"
      ]
    },
    "install": {
      "npmSpec": "openclaw-rest-channel",
      "defaultChoice": "npm"
    }
  },
  "scripts": {
    "lint": "tsc --noEmit"
  },
  "files": [
    "src",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "devDependencies": {
    "openclaw": "latest",
    "typescript": "^5.8.0",
    "rimraf": "^6.0.0"
  }
}
